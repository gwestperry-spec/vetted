require_relative '../../node_modules/@capacitor/ios/scripts/pods_helpers'

platform :ios, '15.0'
use_frameworks!

install! 'cocoapods', :disable_input_output_paths => true

def capacitor_pods
  pod 'Capacitor', :path => '../../node_modules/@capacitor/ios'
  pod 'CapacitorCordova', :path => '../../node_modules/@capacitor/ios'
  pod 'CapacitorCommunityAppleSignIn', :path => '../../node_modules/@capacitor-community/apple-sign-in'
  pod 'CapacitorCommunityInAppReview', :path => '../../node_modules/@capacitor-community/in-app-review'
  # Use the "/Analytics" subspec of @capacitor-firebase/analytics —
  # NOT the default "Lite" subspec. The Analytics subspec declares
  # `FirebaseAnalytics/Core` + `FirebaseAnalytics/IdentitySupport`
  # as dependencies so the plugin target compiles against real
  # Firebase modules. Without this subspec the plugin compiles in
  # Lite mode and `import FirebaseCore` in its own Swift file fails.
  pod 'CapacitorFirebaseAnalytics/Analytics', :path => '../../node_modules/@capacitor-firebase/analytics'
  pod 'CapacitorPushNotifications', :path => '../../node_modules/@capacitor/push-notifications'
end

project 'App.xcodeproj'

target 'App' do
  capacitor_pods
end

post_install do |installer|
  assertDeploymentTarget(installer)
end
